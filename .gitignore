# =============================================================
# SpaceSafe X — Complete .gitignore
# =============================================================

# --- Dependencies ---
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# --- Next.js ---
.next/
out/

# --- Build output ---
build/
dist/

# --- Environment Variables (NEVER commit) ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production
.env.staging
*.env

# --- TypeScript ---
*.tsbuildinfo
next-env.d.ts

# --- Testing ---
coverage/
.nyc_output/

# --- Vercel ---
.vercel

# --- Firebase ---
.firebase/
firebase-debug.log
firestore-debug.log
ui-debug.log

# --- Debug / Logs ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log
logs/

# --- OS ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# --- IDE / Editor ---
.vscode/settings.json
.vscode/launch.json
.vscode/extensions.json
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# --- Misc ---
*.pem
*.key
*.cert
.cache/
.temp/
tmp/
*.tmp
*.bak

# --- Cesium ---
public/cesium/

# --- Secrets ---
secrets/
credentials/
service-account*.json
*-credentials.json
